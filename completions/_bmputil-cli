        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s+[Use the device with the given serial number]:SERIAL_NUMBER:_default' \
'--serial=[Use the device with the given serial number]:SERIAL_NUMBER:_default' \
'--index=[Use the nth found device (may be unstable!)]:INDEX:_default' \
'-p+[Use the device on the given USB port]:PORT:_default' \
'--port=[Use the device on the given USB port]:PORT:_default' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_bmputil-cli_commands" \
"*::: :->bmputil" \
&& ret=0
    case $state in
    (bmputil)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:bmputil-cli-command-$line[1]:"
        case $line[1] in
            (probe)
_arguments "${_arguments_options[@]}" : \
'--allow-dangerous-options=[Allow usage of advanced, dangerous options that can result in unbootable devices (use with heavy caution!)]:ALLOW_DANGEROUS_OPTIONS:(never really)' \
'-s+[Use the device with the given serial number]:SERIAL_NUMBER:_default' \
'--serial=[Use the device with the given serial number]:SERIAL_NUMBER:_default' \
'--index=[Use the nth found device (may be unstable!)]:INDEX:_default' \
